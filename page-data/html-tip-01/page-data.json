"id":"745f34ee-b90a-5d5e-a447-020d34143b77","fields":{"slug":"/angular-hybrid-rendering/"},"frontmatter":{"title":"🍄 Angular Hybrid Rendering"}}},{"node":{"id":"0d449014-0144-5229-a58b-0db88d92ddea","fields":{"slug":"/react-best-practice/"},"frontmatter":{"title":"🌐 React Best Practice"}}},{"node":{"id":"e005d6b7-17d7-506d-9fea-11ac4313b179","fields":{"slug":"/emotion-styledcomponent/"},"frontmatter":{"title":"Emotion VS Styled-Component"}}},{"node":{"id":"60ac7a6b-81a4-5691-a2dc-26e727816ae3","fields":{"slug":"/nextjs-14/"},"frontmatter":{"title":"🤜 Next.js 14 Conf"}}}]},"previous":{"fields":{"slug":"/server-client-side-rendering/"},"frontmatter":{"title":"🔮 Server/Client Side Rendering"}},"next":{"fields":{"slug":"/angular-hybrid-rendering/"},"frontmatter":{"title":"🍄 Angular Hybrid Rendering"}}},"pageContext":{"id":"b2dced4d-c295-57cd-a123-de4f10ad44b3","series":null,"previousPostId":"367af481-7bca-5f7d-a995-37ece8942e7a","nextPostId":"745f34ee-b90a-5d5e-a447-020d34143b77"}},"staticQueryHashes":[],"slicesMap":{}}